# Tenacious-Bench Environment Variables
# Copy this file to .env and fill in your API keys

# OpenRouter for multi-LLM synthesis (optional - offline mode works without this)
# Get your key from https://openrouter.ai/settings
# OPENROUTER_API_KEY=

# HuggingFace for dataset/model publication (required for Act V)
# Get your token from https://huggingface.co/settings/tokens
# HF_TOKEN=

# For training on Colab (free - no API key needed)
# Just authenticate with Google account

# For eval-tier judge (optional - for sealed held-out scoring)
# Only needed if running Delta A/B/C ablations
# ANTHROPIC_API_KEY=  # For Claude Sonnet 4.6
# OPENAI_API_KEY=    # For GPT-5 class