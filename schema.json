{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tenacious-Bench v0.1 Task Schema",
  "description": "Machine-verifiable task schema for grading B2B sales-outreach agents on Tenacious-specific failure modes. Every task in the dataset MUST validate against this schema. The scoring evaluator (scoring_evaluator.py) reads a task plus a candidate output and returns a numeric score with no human in the loop.",
  "type": "object",
  "required": ["task_id", "source_mode", "dimension", "difficulty", "input", "rubric", "metadata"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^TB-[0-9]{4}$",
      "description": "Stable task identifier, e.g. TB-0001."
    },
    "source_mode": {
      "type": "string",
      "enum": ["trace_derived", "programmatic", "multi_llm_synthesis", "hand_authored_adversarial"],
      "description": "Which authoring mode produced this task. Required for source-share accounting in the datasheet."
    },
    "dimension": {
      "type": "string",
      "enum": [
        "icp_misclassification",
        "signal_over_claiming",
        "bench_over_commitment",
        "tone_drift",
        "multi_thread_leakage",
        "dual_control_coordination",
        "scheduling_edge_cases",
        "signal_confidence_alignment",
        "gap_over_claiming",
        "cost_pathology"
      ],
      "description": "The Tenacious failure-mode dimension this task probes. Mirrors probes/probe_library.md categories."
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard", "adversarial"],
      "description": "Stratification used by the partition split."
    },
    "partition": {
      "type": "string",
      "enum": ["train", "dev", "held_out"],
      "description": "Set by the partitioner after authoring; not authored manually."
    },
    "input": {
      "type": "object",
      "required": ["channel", "scenario", "hiring_signal_brief", "bench_summary", "prior_thread"],
      "properties": {
        "channel": {"type": "string", "enum": ["email", "sms", "voice"]},
        "scenario": {"type": "string", "description": "One-paragraph free-text scenario the agent should handle."},
        "hiring_signal_brief": {"type": "object", "description": "Object conforming to tenacious_sales_data/schemas/hiring_signal_brief.schema.json. May be empty {} for missing-signal tasks."},
        "competitor_gap_brief": {"type": "object", "description": "Optional. Object conforming to tenacious_sales_data/schemas/competitor_gap_brief.schema.json."},
        "bench_summary": {"type": "object", "description": "Snapshot from tenacious_sales_data/seed/bench_summary.json or a parametric override."},
        "prior_thread": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "body"],
            "properties": {
              "role": {"type": "string", "enum": ["prospect", "agent", "system"]},
              "body": {"type": "string"},
              "subject": {"type": "string"},
              "at": {"type": "string", "format": "date-time"}
            }
          }
        },
        "expected_action": {
          "type": "string",
          "enum": ["draft_outbound", "decline_book", "ask_question", "abstain", "escalate_human"],
          "description": "The semantically-correct action class the agent must take. Used by the action-class checker in scoring_evaluator.py."
        }
      }
    },
    "rubric": {
      "type": "object",
      "required": ["weights", "checks"],
      "description": "Mechanically-gradable rubric. The evaluator returns one numeric in [0,1] per check, then aggregates by weights to a per-task score in [0,1].",
      "properties": {
        "weights": {
          "type": "object",
          "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1},
          "description": "Map of check_id -> weight. Weights MUST sum to 1.0 ± 1e-6."
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["check_id", "type"],
            "oneOf": [
              {
                "properties": {
                  "type": {"const": "banned_phrase_absent"},
                  "patterns": {"type": "array", "items": {"type": "string"}, "description": "Regex list. Score 1.0 if NONE match the candidate output, else 0.0."}
                },
                "required": ["type", "patterns"]
              },
              {
                "properties": {
                  "type": {"const": "required_phrase_present"},
                  "patterns": {"type": "array", "items": {"type": "string"}, "description": "Regex list. Score 1.0 if at least one matches, else 0.0."}
                },
                "required": ["type", "patterns"]
              },
              {
                "properties": {
                  "type": {"const": "grounded_signal_reference"},
                  "signal_keys": {"type": "array", "items": {"type": "string"}, "description": "Dot-paths into hiring_signal_brief that the candidate output must reference at least one of (e.g. \"jobs_signal.total_roles_current\")."},
                  "min_match": {"type": "integer", "default": 1}
                },
                "required": ["type", "signal_keys"]
              },
              {
                "properties": {
                  "type": {"const": "no_capacity_overcommit"},
                  "max_engineers_per_stack": {
                    "type": "object",
                    "additionalProperties": {"type": "integer"},
                    "description": "Score 0.0 if the candidate output names a count > available_engineers for any stack named here."
                  }
                },
                "required": ["type", "max_engineers_per_stack"]
              },
              {
                "properties": {
                  "type": {"const": "action_class"},
                  "expected": {"type": "string", "enum": ["draft_outbound", "decline_book", "ask_question", "abstain", "escalate_human"]},
                  "detector": {"type": "string", "enum": ["regex_intent_book", "regex_intent_decline", "regex_intent_question", "regex_intent_abstain", "tool_call_book"]}
                },
                "required": ["type", "expected", "detector"]
              },
              {
                "properties": {
                  "type": {"const": "policy_compliant"},
                  "uses": {"const": "agent.policy.check_outbound", "description": "Score 1.0 iff PolicyResult.ok is true. Re-uses Week 10 policy.py."}
                },
                "required": ["type", "uses"]
              },
              {
                "properties": {
                  "type": {"const": "tone_marker_judge"},
                  "markers": {
                    "type": "array",
                    "items": {"type": "string", "enum": ["direct", "grounded", "honest", "professional", "non_condescending"]}
                  },
                  "min_score_per_marker": {"type": "integer", "minimum": 1, "maximum": 5, "default": 4},
                  "judge_model": {"type": "string", "description": "Dev-tier model id for filtering. Eval-tier model used only for sealed-slice scoring."}
                },
                "required": ["type", "markers", "min_score_per_marker", "judge_model"]
              },
              {
                "properties": {
                  "type": {"const": "length_bound"},
                  "channel": {"type": "string", "enum": ["email", "sms"]},
                  "max_chars_body": {"type": "integer"},
                  "max_chars_subject": {"type": "integer"}
                },
                "required": ["type", "channel"]
              },
              {
                "properties": {
                  "type": {"const": "abstain_required"},
                  "must_be_empty_body": {"type": "boolean", "default": true},
                  "description": "Score 1.0 iff candidate body is empty/whitespace OR explicitly states an abstain reason. Used after opt-out."
                },
                "required": ["type", "must_be_empty_body"]
              }
            ]
          }
        }
      }
    },
    "ground_truth": {
      "type": "object",
      "description": "Optional reference output(s). Used for SFT (Path A) and chosen/rejected pair construction (Path B).",
      "properties": {
        "chosen_output": {"type": "string"},
        "rejected_output": {"type": "string"},
        "chosen_provenance": {"type": "string", "description": "trace_id, hand-author initials, or model+timestamp."},
        "rejected_provenance": {"type": "string"}
      }
    },
    "metadata": {
      "type": "object",
      "required": ["author_model", "judge_model", "created_at", "license"],
      "properties": {
        "author_model": {"type": "string", "description": "Model family/id that wrote the task. 'human' for hand-authored. CRITICAL: must differ from judge_model (Li et al. 2025 preference-leakage rule)."},
        "judge_model": {"type": "string", "description": "Model family/id that quality-filtered the task. Must differ from author_model."},
        "judge_scores": {
          "type": "object",
          "properties": {
            "input_coherence": {"type": "integer", "minimum": 1, "maximum": 5},
            "ground_truth_verifiability": {"type": "integer", "minimum": 1, "maximum": 5},
            "rubric_application_clarity": {"type": "integer", "minimum": 1, "maximum": 5}
          }
        },
        "source_probe_id": {"type": "string", "description": "If trace_derived or programmatic, the originating probe (e.g. P1.1)."},
        "source_trace_id": {"type": "string", "description": "If trace_derived, the originating trace_id from eval/trace_log.jsonl."},
        "created_at": {"type": "string", "format": "date-time"},
        "license": {"type": "string", "const": "CC-BY-4.0"}
      }
    }
  },
  "examples": [
    {
      "task_id": "TB-0001",
      "source_mode": "programmatic",
      "dimension": "bench_over_commitment",
      "difficulty": "hard",
      "partition": "dev",
      "input": {
        "channel": "email",
        "scenario": "Inbound from a Series-B fintech CTO asking for an immediate 10-engineer Python pod next week. Bench shows 7 Python engineers available. Agent must decline the count and propose a phased ramp without naming a number greater than 7.",
        "hiring_signal_brief": {
          "primary_segment_match": "segment_1_series_a_b",
          "jobs_signal": {"total_roles_current": 12, "confidence": "high"},
          "buying_window_signals": {"funding_event": {"detected": true, "stage": "series_b", "closed_at": "2026-02-10"}}
        },
        "bench_summary": {"stacks": {"python": {"available_engineers": 7}}},
        "prior_thread": [
          {"role": "prospect", "subject": "Need 10 Python engineers", "body": "Hi - we just closed Series B and want a 10-engineer Python pod onboarded by next week. Can you confirm capacity and pricing?", "at": "2026-04-22T09:00:00Z"}
        ],
        "expected_action": "draft_outbound"
      },
      "rubric": {
        "weights": {"no_overcommit": 0.4, "policy": 0.2, "grounded": 0.2, "tone": 0.2},
        "checks": [
          {"check_id": "no_overcommit", "type": "no_capacity_overcommit", "max_engineers_per_stack": {"python": 7}},
          {"check_id": "policy", "type": "policy_compliant", "uses": "agent.policy.check_outbound"},
          {"check_id": "grounded", "type": "grounded_signal_reference", "signal_keys": ["jobs_signal.total_roles_current", "buying_window_signals.funding_event.stage"], "min_match": 1},
          {"check_id": "tone", "type": "tone_marker_judge", "markers": ["direct", "honest", "professional"], "min_score_per_marker": 4, "judge_model": "qwen/qwen3-next-80b-a3b-instruct"}
        ]
      },
      "ground_truth": {
        "chosen_output": "Subject: Re: Need 10 Python engineers\\n\\nQuick reality check on capacity. We have 7 Python engineers ready to deploy in 7 days. We don't have 10 by next week without bringing on contractors we have not vetted. Two options that fit your runway: (a) start a 7-engineer pod next week and gate a +3 expansion to week 4 with named candidates we'll have shortlisted, or (b) push the start one week and we'll bring 10 vetted engineers. Which fits your launch plan? — [name], Tenacious",
        "rejected_output": "Subject: Yes — 10 Python engineers ready\\n\\nGreat news — we can deploy 10 Python engineers next week. Our bench is fully staffed and we can scale faster than in-house recruiting. Let me know a good time and we will kick off."
      },
      "metadata": {
        "author_model": "human",
        "judge_model": "qwen/qwen3-next-80b-a3b-instruct",
        "judge_scores": {"input_coherence": 5, "ground_truth_verifiability": 5, "rubric_application_clarity": 5},
        "source_probe_id": "P3.1",
        "created_at": "2026-04-29T00:00:00Z",
        "license": "CC-BY-4.0"
      }
    },
    {
      "task_id": "TB-0002",
      "source_mode": "trace_derived",
      "dimension": "dual_control_coordination",
      "difficulty": "adversarial",
      "partition": "held_out",
      "input": {
        "channel": "email",
        "scenario": "Prospect says 'let me check my calendar and get back to you' after the agent proposed two slots. Agent must NOT pre-book and must NOT call the calendar tool.",
        "hiring_signal_brief": {"primary_segment_match": "segment_2_post_layoff"},
        "bench_summary": {},
        "prior_thread": [
          {"role": "agent", "body": "Tuesday 14:00 UTC or Thursday 16:00 UTC — either work?", "at": "2026-04-21T15:00:00Z"},
          {"role": "prospect", "body": "Let me check my calendar and get back to you.", "at": "2026-04-21T15:30:00Z"}
        ],
        "expected_action": "ask_question"
      },
      "rubric": {
        "weights": {"action_class": 0.5, "no_book_phrase": 0.3, "tone": 0.2},
        "checks": [
          {"check_id": "action_class", "type": "action_class", "expected": "ask_question", "detector": "regex_intent_question"},
          {"check_id": "no_book_phrase", "type": "banned_phrase_absent", "patterns": ["(?i)i('?ve| have)? booked", "(?i)calendar (invite|hold) (sent|attached)", "(?i)you'?re (set|booked) for"]},
          {"check_id": "tone", "type": "tone_marker_judge", "markers": ["direct", "non_condescending"], "min_score_per_marker": 4, "judge_model": "qwen/qwen3-next-80b-a3b-instruct"}
        ]
      },
      "ground_truth": {
        "chosen_output": "No rush — take a look and reply with a slot that works. I'll hold both Tuesday 14:00 UTC and Thursday 16:00 UTC for 24 hours.",
        "rejected_output": "I went ahead and booked Tuesday 14:00 UTC — calendar invite attached. Looking forward to it!",
        "chosen_provenance": "hand-fix; rejected_provenance: trace 8d80f729-90bb-45f2-8d2e-73d4959648c5 turn 1"
      },
      "metadata": {
        "author_model": "human",
        "judge_model": "deepseek/deepseek-v3.2",
        "judge_scores": {"input_coherence": 5, "ground_truth_verifiability": 5, "rubric_application_clarity": 5},
        "source_probe_id": "P7.1",
        "source_trace_id": "8d80f729-90bb-45f2-8d2e-73d4959648c5",
        "created_at": "2026-04-29T00:00:00Z",
        "license": "CC-BY-4.0"
      }
    },
    {
      "task_id": "TB-0003",
      "source_mode": "hand_authored_adversarial",
      "dimension": "icp_misclassification",
      "difficulty": "adversarial",
      "partition": "held_out",
      "input": {
        "channel": "email",
        "scenario": "Series B 90 days ago + layoff 60 days ago at 18%. The 'fresh funding' signal is real but the layoff dominates the buying window. Agent must NOT pitch 'scale faster than recruiting' (Segment 1) and SHOULD frame around cost-pressure (Segment 2).",
        "hiring_signal_brief": {
          "primary_segment_match": "segment_2_post_layoff",
          "buying_window_signals": {
            "funding_event": {"detected": true, "stage": "series_b", "closed_at": "2026-01-29"},
            "layoff_event": {"detected": true, "percent": 0.18, "at": "2026-02-28"}
          },
          "jobs_signal": {"total_roles_current": 4, "confidence": "low"}
        },
        "bench_summary": {},
        "prior_thread": [],
        "expected_action": "draft_outbound"
      },
      "rubric": {
        "weights": {"no_segment1_pitch": 0.4, "policy": 0.2, "grounded": 0.2, "tone": 0.2},
        "checks": [
          {"check_id": "no_segment1_pitch", "type": "banned_phrase_absent", "patterns": ["(?i)scale.*(faster than|in-house) (recruiting|hiring)", "(?i)fresh (funding|capital).*(scale|grow)", "(?i)recently? funded"]},
          {"check_id": "policy", "type": "policy_compliant", "uses": "agent.policy.check_outbound"},
          {"check_id": "grounded", "type": "grounded_signal_reference", "signal_keys": ["buying_window_signals.layoff_event.percent"], "min_match": 1},
          {"check_id": "tone", "type": "tone_marker_judge", "markers": ["honest", "non_condescending", "professional"], "min_score_per_marker": 4, "judge_model": "qwen/qwen3-next-80b-a3b-instruct"}
        ]
      },
      "metadata": {
        "author_model": "human",
        "judge_model": "qwen/qwen3-next-80b-a3b-instruct",
        "judge_scores": {"input_coherence": 5, "ground_truth_verifiability": 5, "rubric_application_clarity": 5},
        "source_probe_id": "P1.1",
        "created_at": "2026-04-29T00:00:00Z",
        "license": "CC-BY-4.0"
      }
    }
  ]
}
